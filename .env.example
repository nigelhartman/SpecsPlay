# ===== API Keys =====
# Use one of the following for music generation:
# - GEMINI_API_KEY: Google Gemini API key (from Google Cloud Console)
# - OPENROUTER_API_KEY: OpenRouter API key (supports multiple providers)
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===== Server Configuration =====
# Port for the backend server (default: 3000)
PORT=3000

# Base URL for the server (used for callback URLs, file downloads)
# For local development: http://localhost:3000
# For production: https://yourdomain.com
BASE_URL=http://localhost:3000

# Secret key for secure operations (generate a random string)
SECRET_KEY=your_secret_key_here
